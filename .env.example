# france-budget-simulateur — Variables d'environnement (toutes optionnelles)
# Copier ce fichier en .env et adapter à votre déploiement.

# Mode debug — expose les stack traces dans les réponses 5xx et active uvicorn reload.
# Ne JAMAIS activer en production.
DEBUG_MODE=false

# Origines CORS autorisées (CSV). Défaut : localhost dev uniquement.
# Exemple production : CORS_ORIGINS=https://example.org,https://www.example.org
# CORS_ORIGINS=http://localhost:3000

# Port et hôte d'écoute de l'API (utilisés uniquement quand on lance `python api.py`).
# API_HOST=0.0.0.0
# API_PORT=8000
